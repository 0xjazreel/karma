# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_from_botfather
HELIUS_API_KEY=your_helius_api_key

# ── Optional ──────────────────────────────────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key

# ── Tuning ────────────────────────────────────────────────────────────────────
# Minimum completed trades for a wallet to qualify
MIN_TRADES=20
# Minimum win-rate threshold (0.0–1.0)
MIN_WIN_RATE=0.60
# How often (hours) to run a full discovery scan
SCAN_INTERVAL_HOURS=6
# How often (seconds) to poll tracked wallets for new transactions
TRACK_POLL_SECONDS=30
# Max wallets to hold in the tracked set
MAX_TRACKED_WALLETS=100
# SQLite database file path
DATABASE_PATH=karma_bot.db
