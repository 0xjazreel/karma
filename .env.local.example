# Copy this to .env.local — fill in after deploying contracts + agent

# From contracts/deployments.json (mainnet section)
NEXT_PUBLIC_REGISTRY_ADDRESS=0x_FILL_FROM_DEPLOYMENTS_JSON
NEXT_PUBLIC_HOOK_ADDRESS=0x_FILL_FROM_DEPLOYMENTS_JSON

# Your Railway agent URL — e.g. https://karma-agent-production.up.railway.app
# The frontend will fetch /status from this URL every 20s
NEXT_PUBLIC_AGENT_URL=https://YOUR_RAILWAY_APP.up.railway.app
